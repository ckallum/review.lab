{
  "name": "reviewdev",
  "version": "0.0.0",
  "description": "Local PR review surface for agent-authored code.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "reviewdev": "./src/cli.ts"
  },
  "scripts": {
    "reviewdev": "bun run src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "hono": "^4.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "prettier": "^3.6.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
