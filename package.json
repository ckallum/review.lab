{
  "name": "reviewdev",
  "version": "0.0.0",
  "description": "Local PR review surface for agent-authored code.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "reviewdev": "./src/cli.ts"
  },
  "scripts": {
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "typecheck": "tsc --noEmit",
    "roadmap": "bun scripts/gen-roadmap.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "hono": "^4.12.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "prettier": "^3.8.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.0"
  }
}
